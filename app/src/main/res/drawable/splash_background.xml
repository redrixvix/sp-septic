<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="108dp"
    android:layout_height="108dp"
    android:gravity="center">

    <!-- Warm cream background matching app theme -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FEFAE0"/>
        </shape>
    </item>

    <!-- Subtle warm radial glow behind the icon -->
    <item android:gravity="center">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="80dp"
                android:startColor="#FAEDCD"
                android:endColor="#FEFAE0"/>
            <size android:width="160dp" android:height="160dp"/>
        </shape>
    </item>

</layer-list>